# Application Configuration — TEST
APP_NAME="RedCrossQuest V2 API"
ENVIRONMENT=test
DEBUG=false

# Database - MySQL RCQ (read-only)
RCQ_DB_HOST=localhost
RCQ_DB_PORT=3316
RCQ_DB_NAME=rcq_fr_test_db
RCQ_DB_USER=rcq_readonly
RCQ_DB_PASSWORD=

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=https://test.graph.redcrossquest.com

# Google OAuth (Wave 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://back.test.graph.redcrossquest.com/api/auth/callback

# Session/JWT (Wave 2)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Superset (Wave 2)
SUPERSET_URL=https://superset.test.graph.redcrossquest.com
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=

# Dashboard Embedding UUIDs
# Get these from Superset: Dashboard → ⋮ → Embed dashboard → UUID
SUPERSET_DASHBOARD_YEARLY_GOAL=
