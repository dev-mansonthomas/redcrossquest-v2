# Application Configuration
APP_NAME="RedCrossQuest V2 API"
ENVIRONMENT=dev
DEBUG=true

# Database - MySQL RCQ (read-only)
RCQ_DB_HOST=localhost
RCQ_DB_PORT=3306
RCQ_DB_NAME=rcq_fr_dev_db
RCQ_DB_USER=rcq_readonly
RCQ_DB_PASSWORD=your_password_here

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# Google OAuth (Wave 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Session/JWT (Wave 2)
JWT_SECRET_KEY=

# Metabase (Wave 2)
METABASE_SECRET_KEY=
METABASE_SITE_URL=
