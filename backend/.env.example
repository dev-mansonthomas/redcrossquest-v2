# Application Configuration
APP_NAME="RedCrossQuest V2 API"
ENVIRONMENT=dev
DEBUG=true

# Database - MySQL RCQ
RCQ_DB_HOST=localhost
RCQ_DB_PORT=3316
RCQ_DB_NAME=rcq_fr_dev_db
RCQ_DB_USER=rcq-graph
RCQ_DB_PASSWORD=rcq_password

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4210,http://localhost:8080

# Google OAuth (Wave 2)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Session/JWT (Wave 2)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# Superset (Wave 2)
SUPERSET_URL=http://localhost:8088
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=

# Dashboard Embedding UUIDs
# Get these from Superset: Dashboard → ⋮ → Embed dashboard → UUID
SUPERSET_DASHBOARD_YEARLY_GOAL=
