# ============================================================
# RedCrossQuest V2 — Environment Configuration
# ============================================================
#
# This file documents ALL environment variables used across
# the project. It serves two purposes:
#
# 1. LOCAL DEVELOPMENT: Copy to .env at root
#      cp .env.example .env
#    All Docker Compose services read from this single file.
#
# 2. GCP DEPLOYMENT: Copy to .env.dev, .env.test, or .env.prod
#      cp .env.example .env.dev
#
# Variables marked [LOCAL] are only needed for local dev.
# Variables marked [GCP] are only needed for GCP deployments.
# Variables without a tag are used in both environments.
# ============================================================

# ── Environment ──────────────────────────────────────────────
# Environment: dev, test, prod (must match Pydantic Settings literal)
ENVIRONMENT=dev
DEBUG=false

# ── GCP Project [GCP] ───────────────────────────────────────
GCP_PROJECT_ID=rcq-fr-dev
GCP_REGION=europe-west1

# ── Docker / Artifact Registry [GCP] ────────────────────────
AR_REPOSITORY=rcq-docker

# ── Backend (FastAPI) ────────────────────────────────────────
APP_NAME="RedCrossQuest V2 API"
# [LOCAL] API_URL=http://localhost:8010
API_URL=

# ── Frontend (Angular) [LOCAL] ───────────────────────────────
# [LOCAL] FRONTEND_URL=http://localhost:4210
FRONTEND_URL=

# ── Database — MySQL ────────────────────────────────────────
# [LOCAL] MySQL Docker container root password
MYSQL_ROOT_PASSWORD=
# [LOCAL] Database auto-created by MySQL Docker image
MYSQL_DATABASE=rcq_fr_dev_db
MYSQL_USER=rcq_readonly
MYSQL_PASSWORD=
# Backend connection (read + targeted writes)
# [GCP] RCQ_DB_PASSWORD stored in Secret Manager: rcq_db_graph_password
# [LOCAL] RCQ_DB_HOST=localhost, RCQ_DB_PORT=3316
RCQ_DB_HOST=
RCQ_DB_PORT=3306
RCQ_DB_NAME=rcq_fr_dev_db
RCQ_DB_USER=rcq-graph
RCQ_DB_PASSWORD=

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=https://dev.graph.redcrossquest.com

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dev.back.graph.redcrossquest.com/api/auth/callback

# JWT — Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# ── Superset ─────────────────────────────────────────────────
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=
SUPERSET_ADMIN_EMAIL=admin@rcq.local
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User

# Superset URL (backend → Superset API calls)
# [LOCAL] SUPERSET_URL=http://rcq_superset:8088 (Docker internal)
# [GCP]   SUPERSET_URL=https://dev.superset.graph.redcrossquest.com
SUPERSET_URL=https://dev.superset.graph.redcrossquest.com

# [LOCAL] Browser-accessible Superset URL (for frontend iframe embedding)
# SUPERSET_DOMAIN=http://localhost:8088
SUPERSET_DOMAIN=

# Superset CORS (comma-separated origins)
SUPERSET_CORS_ORIGINS=https://dev.graph.redcrossquest.com,https://dev.back.graph.redcrossquest.com

# ── Superset Provisioning ───────────────────────────────────
# Database connection string for Superset to connect to MySQL
DB_CONNECTION_NAME="RCQ MySQL Dev"
# DB_SQLALCHEMY_URI — Généré automatiquement par gcp-deploy.sh
# à partir de RCQ_DB_USER, RCQ_DB_PASSWORD, RCQ_DB_HOST, RCQ_DB_PORT, RCQ_DB_NAME
# Ne pas remplir manuellement.
# DB_SQLALCHEMY_URI=

# Embedding allowed domains (frontend URL)
EMBEDDING_ALLOWED_DOMAINS=https://dev.graph.redcrossquest.com

# ── Dashboard Embedding UUIDs ────────────────────────────────
# Get these from Superset: Dashboard → ⋮ → Embed dashboard → UUID
SUPERSET_DASHBOARD_YEARLY_GOAL=
SUPERSET_DASHBOARD_COMPTAGE_TRESORIER=
SUPERSET_DASHBOARD_LEADERBOARD=

# ── Database Migrations ──────────────────────────────────────
# For GCP: credentials to run migrations (typically via Cloud SQL Proxy)
MIGRATION_DB_HOST=127.0.0.1
MIGRATION_DB_PORT=3306
MIGRATION_DB_USER=root
MIGRATION_DB_PASSWORD=
MIGRATION_DB_NAME=rcq_fr_dev_db

# ── Cloud SQL Proxy ──────────────────────────────────────────
# Utilisé par: gcp-deploy.sh (pour accéder à Cloud SQL depuis un poste local)
# Format: project:region:instance
CLOUD_SQL_CONNECTION_NAME=rcq-fr-dev:europe-west1:rcq-db-inst-fr-dev-0
CLOUD_SQL_PROXY_PORT=3305

# ── Valkey (Memorystore for Valkey 9 sur GCP) ────────────────
# Utilisé par:
#   - Superset: cache (data, filter, explore), Celery broker + result backend (DB 1)
#   - Backend: cache (DB 0, réservé pour usage futur)
# Sur GCP: Memorystore for Valkey 9 avec IAM Auth (pas de mot de passe)
# En local: valkey-bundle Docker (avec module JSON) sans auth
# [LOCAL] VALKEY_HOST=rcq_valkey (Docker internal), VALKEY_PORT=6379
# [LOCAL] From host: localhost:6389
VALKEY_HOST=rcq_valkey
VALKEY_PORT=6379
VALKEY_DB=0
