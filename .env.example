# ============================================================
# RedCrossQuest V2 — GCP Deployment Configuration
# ============================================================
#
# This is the SINGLE configuration file for GCP deployments.
# Copy to .env.dev, .env.test, or .env.prod and fill in values.
#
#   cp .env.example .env.dev
#   cp .env.example .env.test
#   cp .env.example .env.prod
#
# The local dev environment uses separate .env.example files
# in each component directory (backend/, superset/, etc.).
# ============================================================

# ── GCP Project ──────────────────────────────────────────────
GCP_PROJECT_ID=rcq-fr-dev
GCP_REGION=europe-west1

# ── Docker / Artifact Registry ───────────────────────────────
# Registry name in Artifact Registry (default: rcq-docker)
AR_REPOSITORY=rcq-docker

# ── Backend (FastAPI) ────────────────────────────────────────
APP_NAME="RedCrossQuest V2 API"
ENVIRONMENT=dev
DEBUG=false

# ── Database Read-Only User ─────────────────────────────────
# Utilisé par: backend, superset (via Secret Manager en prod)
# Le mot de passe est stocké dans Secret Manager: rcq_db_readonly_password_{env}
# En local, le mot de passe est dans cette variable :
RCQ_DB_HOST=
RCQ_DB_PORT=3306
RCQ_DB_NAME=rcq_fr_dev_db
RCQ_DB_USER=rcq_readonly
RCQ_DB_PASSWORD=rcq_password

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=https://dev.graph.redcrossquest.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://back.dev.graph.redcrossquest.com/api/auth/callback

# JWT — Generate with: openssl rand -hex 32
JWT_SECRET_KEY=

# ── Superset ─────────────────────────────────────────────────
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=
SUPERSET_ADMIN_EMAIL=admin@rcq.local
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User

# Superset URL (the deployed URL, used by backend + provisioning)
SUPERSET_URL=https://superset.dev.graph.redcrossquest.com

# Superset CORS (comma-separated origins)
SUPERSET_CORS_ORIGINS=https://dev.graph.redcrossquest.com,https://back.dev.graph.redcrossquest.com

# ── Superset Provisioning ───────────────────────────────────
# Database connection string for Superset to connect to MySQL
DB_CONNECTION_NAME=RCQ MySQL Dev
DB_SQLALCHEMY_URI=mysql+mysqldb://user:password@host:port/rcq_fr_dev_db

# Embedding allowed domains (frontend URL)
EMBEDDING_ALLOWED_DOMAINS=https://dev.graph.redcrossquest.com

# ── Dashboard Embedding UUIDs ────────────────────────────────
# Get these from Superset: Dashboard → ⋮ → Embed dashboard → UUID
SUPERSET_DASHBOARD_YEARLY_GOAL=

# ── Database Migrations ──────────────────────────────────────
# For GCP: credentials to run migrations (typically via Cloud SQL Proxy)
MIGRATION_DB_HOST=127.0.0.1
MIGRATION_DB_PORT=3306
MIGRATION_DB_USER=root
MIGRATION_DB_PASSWORD=
MIGRATION_DB_NAME=rcq_fr_dev_db

# ── MySQL (Cloud SQL) ───────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=rcq_fr_dev_db
MYSQL_USER=rcq_readonly
MYSQL_PASSWORD=

# ── Valkey (Redis-compatible cache for Superset) ────────────
VALKEY_HOST=valkey
VALKEY_PORT=6389
VALKEY_DB=1
