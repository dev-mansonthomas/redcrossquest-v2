# Metabase Application Database Configuration
# This is where Metabase stores its own metadata (users, dashboards, queries, etc.)
MB_DB_DBNAME=rcq_metabase_db
MB_DB_PORT=3306
MB_DB_USER=rcq_metabase_user
MB_DB_PASS=CHANGE_ME_STRONG_PASSWORD
MB_DB_HOST=rcq_mysql

# MySQL Root Password (for local dev only)
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Metabase Site Configuration
MB_SITE_URL=http://localhost:3010
MB_EMBEDDING_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_KEY

# RCQ Data Source Configuration (read-only access)
# These will be configured in Metabase UI after first setup
# Database name: rcq_fr_dev_db (or rcq_fr_test_db, rcq_fr_prod_db)
# User: rcq_readonly_user (created by init-scripts/03-create-readonly-user.sh)
# Password: Set during user creation
#
# IMPORTANT: The RCQ schema is NOT created automatically.
# You must import your own database dump. See IMPORT_DATA.md for instructions.
# Place your SQL dump files in the sql-imports/ directory.
