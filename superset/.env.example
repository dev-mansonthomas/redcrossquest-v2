# ===========================================
# RCQ V2 — Superset + MySQL Docker Environment
# ===========================================

# MySQL 8.0
MYSQL_ROOT_PASSWORD=rcq_root_password
MYSQL_DATABASE=rcq_fr_dev_db
MYSQL_USER=rcq_readonly
MYSQL_PASSWORD=rcq_password

# Superset
SUPERSET_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@rcq.local
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User

# Superset CORS (comma-separated origins)
SUPERSET_CORS_ORIGINS=http://localhost:4210,http://localhost:8010

# Valkey
VALKEY_HOST=valkey
VALKEY_PORT=6389
VALKEY_DB=1
