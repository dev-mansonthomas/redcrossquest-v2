# Superset Provisioning Configuration — TEST

# Superset connection
SUPERSET_URL=https://superset.test.graph.redcrossquest.com
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=

# Database connection to create in Superset
DB_CONNECTION_NAME=RCQ MySQL Test
DB_SQLALCHEMY_URI=mysql+mysqldb://user:password@host:port/rcq_fr_test_db

# Optional: Override embedding domain
EMBEDDING_ALLOWED_DOMAINS=https://test.graph.redcrossquest.com

# Backend configuration (optional, defaults to ../../backend/.env)
BACKEND_ENV_PATH=../../backend/.env.test
