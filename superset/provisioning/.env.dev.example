# Superset Provisioning Configuration — DEV

# Superset connection
SUPERSET_URL=https://superset.dev.graph.redcrossquest.com
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=

# Database connection to create in Superset
DB_CONNECTION_NAME=RCQ MySQL Dev
DB_SQLALCHEMY_URI=mysql+mysqldb://user:password@host:port/rcq_fr_dev_db

# Optional: Override embedding domain
EMBEDDING_ALLOWED_DOMAINS=https://dev.graph.redcrossquest.com

# Backend configuration (optional, defaults to ../../backend/.env)
BACKEND_ENV_PATH=../../backend/.env.dev
