# Superset Provisioning Configuration
# Copy this file to .env.{env} (e.g., .env.dev, .env.test, .env.prod)

# Superset connection
SUPERSET_URL=http://localhost:8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=

# Database connection to create in Superset
DB_CONNECTION_NAME=RCQ MySQL
DB_SQLALCHEMY_URI=mysql+mysqldb://user:password@host:port/database

# Optional: Override embedding domain
EMBEDDING_ALLOWED_DOMAINS=http://localhost:4210

# Backend configuration (optional, defaults to ../../backend/.env)
BACKEND_ENV_PATH=../../backend/.env

